// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id               String          @id @default(uuid()) @db.Char(36)
  login            String          @unique @db.VarChar(40)
  email            String          @unique @db.VarChar(255)
  password         String
  googleId         String?         @unique @db.VarChar(255)
  eloRating        Int             @default(400)
  xp               Int             @default(0)
  gamesAsP1        Game[]          @relation("Player1")
  gamesAsP2        Game[]          @relation("Player2")
  friendRequestsSent    FriendRequest[] @relation("FriendRequestFrom")
  friendRequestsReceived FriendRequest[] @relation("FriendRequestTo")
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([email])
}

enum FriendStatus {
  PENDING
  ACCEPTED
}

model FriendRequest {
  id         String       @id @default(uuid()) @db.Char(36)
  fromUserId String       @db.Char(36)
  toUserId   String       @db.Char(36)
  status     FriendStatus @default(PENDING)
  fromUser   User         @relation("FriendRequestFrom", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser     User         @relation("FriendRequestTo", fields: [toUserId], references: [id], onDelete: Cascade)
  createdAt  DateTime     @default(now())

  @@unique([fromUserId, toUserId])
  @@index([toUserId])
}

enum GameWinner {
  DRAW
  PLAYER1
  PLAYER2
}

model Game {
  id        String     @id @default(uuid()) @db.Char(36)
  player1Id String     @db.Char(36)
  player2Id String     @db.Char(36)
  winner    GameWinner
	eloDelta1 Int
	eloDelta2 Int
  moves     Json
  duration  Int
  player1   User       @relation("Player1", fields: [player1Id], references: [id])
  player2   User       @relation("Player2", fields: [player2Id], references: [id])
  createdAt DateTime   @default(now())

  @@index([player1Id])
  @@index([player2Id])
}
